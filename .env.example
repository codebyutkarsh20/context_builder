# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model used for LLM-powered chat and context Q&A
ANTHROPIC_MODEL=claude-sonnet-4-6

# Model used for background summarisation (cheaper/faster)
# SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── Neo4j ──────────────────────────────────────────────────────
# Default password matches docker-compose.yml. Change both if exposing to network.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=contextbuilder

# ── Backend ────────────────────────────────────────────────────
# Directory where analysed context files + per-repo lessons are stored.
# When running via docker-compose, this is /data (a named volume).
# When running CLI directly on host, defaults to /tmp/context_builder
# (override here for persistent storage, e.g. ~/context_builder_data).
# DATA_DIR=/data

# Comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Base directory that repo paths must be under (prevents path traversal)
# REPOS_BASE_DIR=/repos

# Docker: host directory to mount into the backend container so the agent
# can analyze your local repos. Defaults to $HOME. Change if your code
# lives elsewhere (e.g. /Volumes/Work).
# USER_REPOS_HOST=/Users/yourname/code

# ── Frontend ───────────────────────────────────────────────────
# Backend API URL. Port 8001 matches docker-compose.yml.
VITE_API_BASE_URL=http://localhost:8001

# ── Agent ──────────────────────────────────────────────────────
# Which mode the background agent should run in
AGENT_MODE=explore

# ── Optional: GitHub PR creation ───────────────────────────────
# Required if you want the agent to push branches and open PRs.
# Create a token at https://github.com/settings/tokens with `repo` scope.
# GH_TOKEN=ghp_...
