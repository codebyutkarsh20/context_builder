# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model used for LLM-powered chat and context Q&A
ANTHROPIC_MODEL=claude-sonnet-4-6

# Model used for background summarisation (cheaper/faster)
# SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Backend ────────────────────────────────────────────────────
# Directory where analysed context files are stored
# DATA_DIR=/data

# Comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Base directory that repo paths must be under (prevents path traversal)
# REPOS_BASE_DIR=/repos

# ── Frontend ───────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Agent ──────────────────────────────────────────────────────
# Which mode the background agent should run in
AGENT_MODE=explore
