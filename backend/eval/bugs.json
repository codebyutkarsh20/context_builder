    "fix_sha": "1708c37dc3842894da9db700194979c6f90f7b17",
    "expected_files": [
      "backend/agent/sandbox.py"
    ],
    "expected_patch_files": [
      "backend/agent/sandbox.py"
    ],
    "expected_root_cause": "run_tests uses str.split() instead of shlex.split() for test_cmd_base parsing",
    "difficulty": "single-file",
    "source": "context_builder-internal",
    "priority": "medium",
    "category": "api-misuse",
    "language": "python",
    "repo_name": "context_builder",
    "swe_bench_id": null,
    "setup_commands": [
      "pip install -e backend/"
    ],
    "test_command": "pytest backend/tests/test_phase2a_fixes.py -v",
    "tags": [
      "sandbox",
      "subprocess",
      "single-file"
    ],
    "comments": [
      "The bug is on line 86 of sandbox.py: `cmd_parts = test_cmd_base.split()` should be `shlex.split(test_cmd_base)`.",
      "shlex is already imported (line 13). The fix is literally changing .split() to shlex.split().",
      "At SHA 90d9c72, line 76 already uses shlex.split() for setup_commands \u2014 so this is an inconsistency."
